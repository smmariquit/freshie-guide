---
import '../styles/globals.css';
import VisitorCount from '../components/VisitorCount.astro';
import LegalMicroLink from '../components/LegalMicroLink.astro';

interface Props {
	title?: string;
	description?: string;
	guide?: {
		slug: string;
		label: string;
		icon: string;
	};
}

const { 
	title = "Stimmie's Guides", 
	description = "Guides and handbooks written by Stimmie.",
	guide,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌻</text></svg>" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/embed.webp" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="/embed.webp" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
		</noscript>
		<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9785940474424207"
		     crossorigin="anonymous" is:inline></script>
	</head>
	<body class="font-sans">
		<slot />
		<footer class="site-footer">
			<a href="https://stimmie.dev" class="site-footer-link">&larr; stimmie.dev</a>
			{!guide && <VisitorCount />}
			<LegalMicroLink />
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--font-inter: 'Inter', sans-serif;
	}
	html {
		font-family: var(--font-inter);
	}
</style>
